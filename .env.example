# ==============================================
# BES Environment Configuration
# ==============================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# NEVER commit the actual .env file to git.
# ==============================================

# Email configuration (Gmail SMTP)
EMAIL=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# PostgreSQL database
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/bes_db
SPRING_DATASOURCE_USERNAME=bes_admin
SPRING_DATASOURCE_PASSWORD=change-me-to-a-strong-password
SPRING_DATASOURCE_DBNAME=bes_db

# Application domain (with protocol)
DOMAIN=https://your-domain.com

# Cookie domain (use your actual domain in production, 'localhost' for dev)
# For local network with .local mDNS, set this to your hostname (e.g., blim.local)
BES_COOKIE_DOMAIN=localhost

# Set to false for local dev without HTTPS (e.g., .local mDNS on local network)
# Keep true for production with real SSL certificates
BES_SECURE_COOKIE=true

# Application user passwords (set strong passwords in production)
BES_ADMIN_PASSWORD=change-me-admin
BES_EMCEE_PASSWORD=change-me-emcee
BES_JUDGE_PASSWORD=change-me-judge
BES_ORGANISER_PASSWORD=change-me-organiser

# WebSocket allowed origins (comma-separated, no spaces)
BES_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80
